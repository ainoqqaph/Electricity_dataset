	column PowerUsage_100M_kWh
		dataType: double
		lineageTag: fa0b0003-fa0b-4003-800b-fa0b0000000b
		summarizeBy: sum
		sourceColumn: PowerUsage_100M_kWh

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column StationName
		dataType: string
		lineageTag: fa0b0004-fa0b-4004-800b-fa0b0000000b
		summarizeBy: none
		sourceColumn: StationName

