table Fact_ClimateData_Analytics
	lineageTag: fa0b0000-fa0b-4000-800b-fa0b0000000b

	column YearMonth
		dataType: int64
		lineageTag: fa0b0001-fa0b-4001-800b-fa0b0000000b
		summarizeBy: sum
		sourceColumn: YearMonth

		annotation SummarizationSetBy = Automatic

	column District
		dataType: string
		lineageTag: fa0b0002-fa0b-4002-800b-fa0b0000000b
		summarizeBy: none
		sourceColumn: District

