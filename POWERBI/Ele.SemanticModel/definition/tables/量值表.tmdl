	measure 園區用電_YoY% =
			
			VAR CY = [園區高壓用電_億度]
			VAR PY = CALCULATE([園區高壓用電_億度], SAMEPERIODLASTYEAR(Dim_Date[Date]))
			RETURN DIVIDE(CY - PY, PY)
		formatString: 0.00%
		displayFolder: 時間智慧
		lineageTag: ee220000-ee22-4000-8022-ee2200000000

	measure 三園四象限分類 =
			
			VAR elec_yoy = [園區用電_YoY%]
			VAR rev_yoy  = [園區營業額_YoY%]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(elec_yoy) || ISBLANK(rev_yoy), BLANK(),
			        elec_yoy >= 0 && rev_yoy >= 0, "高用電高營收",
			        elec_yoy >= 0 && rev_yoy < 0,  "高用電低營收（效率警示）",
			        elec_yoy < 0  && rev_yoy >= 0, "節能增收（最佳）",
			        "縮減期"
			    )
		displayFolder: 四象限
		lineageTag: ee230000-ee23-4000-8023-ee2300000000

