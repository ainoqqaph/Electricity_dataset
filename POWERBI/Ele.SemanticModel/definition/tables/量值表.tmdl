	measure 備轉容量率_月最低均 =
			AVERAGEX(
			    SUMMARIZE(
			        'Fact_備轉容量日',
			        Dim_Date[YearMonth],
			        "月最低", MIN('Fact_備轉容量日'[備轉容量率_pct])
			    ),
			    [月最低]
			)
		displayFolder: L1_電網韌性\再生能源結構
		lineageTag: a3010005-a301-4005-8005-a30100000005

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 夏季備轉率_均 =
			CALCULATE(
			    AVERAGE('Fact_備轉容量日'[備轉容量率_pct]),
			    Dim_Date[Month] IN {6, 7, 8}
			)
		displayFolder: L1_電網韌性\再生能源結構
		lineageTag: a3010006-a301-4006-8006-a30100000006

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 夏季低備轉天數 = CALCULATE([低備轉天數], Dim_Date[Month] IN {6, 7, 8})
		displayFolder: L1_電網韌性\再生能源結構
		lineageTag: a3010007-a301-4007-8007-a30100000007

	measure 再生能源佔比_2018基準 =
			CALCULATE(
			    [再生能源佔比_%],
			    ALL(Dim_Date),
			    Dim_Date[Year] = 2018
			)
		formatString: 0.00%
		displayFolder: L1_電網韌性\再生能源結構
		lineageTag: a3010008-a301-4008-8008-a30100000008

	measure 再生能源成長_百分點 = [再生能源佔比_%] - [再生能源佔比_2018基準]
		formatString: 0.00%
		displayFolder: L1_電網韌性\再生能源結構
		lineageTag: a3010009-a301-4009-8009-a30100000009

	measure 民生用電_佔比_% = DIVIDE([民生用電_百萬度], [工業用電_百萬度] + [民生用電_百萬度])
		displayFolder: KPI量值
		lineageTag: a5f5e87a-929f-4f42-9d8d-c93f450b4e7f

