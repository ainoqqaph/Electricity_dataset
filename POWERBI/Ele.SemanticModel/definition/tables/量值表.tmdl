		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 背離指數_排名 =
			
			RANKX(
			    ALLSELECTED('Fact_電力背離'[District]),
			    [電力背離指數],
			    ,
			    DESC
			)
		displayFolder: L3_數位足跡
		lineageTag: ee330000-ee33-4000-8033-ee3300000000

	measure 高負載月數_>80pct =
			
			COUNTROWS(
			    FILTER(
			        VALUES(Dim_Date[YearMonth]),
			        [園區負載率_%] > 0.8
			    )
			)
		displayFolder: L3_數位足跡
		lineageTag: ee340000-ee34-4000-8034-ee3400000000

	measure 峰值負載_YoY% =
			
			VAR CY = [園區峰值負載_萬KW]
			VAR PY = CALCULATE([園區峰值負載_萬KW], SAMEPERIODLASTYEAR(Dim_Date[Date]))
			RETURN DIVIDE(CY - PY, PY)
		formatString: 0.00%
		displayFolder: L3_數位足跡
		lineageTag: ee350000-ee35-4000-8035-ee3500000000

	measure 製造業景氣共振指數 =
			
			VAR deviation  = [電力背離指數]
			VAR mfg_growth = [生產指數_YoY%]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(deviation) || ISBLANK(mfg_growth), BLANK(),
			        deviation > 0.5 && mfg_growth > 0.05,  "強共振（AI+景氣雙驅動）",
			        deviation > 0.5 && mfg_growth <= 0.05, "背離主導（AI超前景氣）",
			        deviation <= 0  && mfg_growth > 0.05,  "景氣未反映用電",
			        "正常範圍"
			    )
		displayFolder: L3_數位足跡
		lineageTag: ee360000-ee36-4000-8036-ee3600000000

	measure 電力消費_億度 = DIVIDE(SUM('Fact_電力密集度年'[電力消費_千度]), 100000)
		formatString: 0.00
		displayFolder: L2_電力效能
		lineageTag: ee370000-ee37-4000-8037-ee3700000000

	measure PENDING_已入區廠商數 = BLANK()
		displayFolder: PENDING
		lineageTag: ee380000-ee38-4000-8038-ee3800000000

	measure 電力消費_YoY% =
			VAR CY = [電力消費_億度]
			VAR PY = CALCULATE([電力消費_億度], SAMEPERIODLASTYEAR(Dim_Date[Date]))
			RETURN DIVIDE(CY - PY, PY)
		formatString: 0.00%
		displayFolder: L2_電力效能
		lineageTag: ee390000-ee39-4000-8039-ee3900000000

	measure 四象限分類 =
			VAR elec_yoy = [電力消費_YoY%]
			VAR prod_yoy = [生產指數_YoY%]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(elec_yoy) || ISBLANK(prod_yoy), BLANK(),
			        elec_yoy >= 0 && prod_yoy >= 0, "高用電高生產",
			        elec_yoy >= 0 && prod_yoy < 0,  "高用電低生產（效率警示）",
			        elec_yoy < 0  && prod_yoy >= 0, "低用電高生產（效率提升）",
			        "低用電低生產（景氣低迷）"
			    )
		displayFolder: L2_電力效能
		lineageTag: ee3a0000-ee3a-4000-803a-ee3a00000000

	measure 用電彈性 = DIVIDE([電力消費_YoY%], [生產指數_YoY%])
		formatString: 0.00
		displayFolder: L2_電力效能
		lineageTag: ee3b0000-ee3b-4000-803b-ee3b00000000

	measure GDP用電脫鉤指數 = DIVIDE([GDP份額%], [用電份額%])
		formatString: 0.00
		displayFolder: L2_電力效能
		lineageTag: ee3c0000-ee3c-4000-803c-ee3c00000000

	measure 高壓用電指數 = ```
			
			  VAR base = CALCULATE(
			      SUM('Fact_TechHubPower'[PowerUsage_100M_kWh]),
			      'Dim_Date'[Year] = 2016,
			      ALL('Dim_Date')
			  )
			  RETURN DIVIDE(SUM('Fact_TechHubPower'[PowerUsage_100M_kWh]), base) 
			```
		formatString: 0.00
		displayFolder: L3_數位足跡
		lineageTag: a3376060-f248-4d6b-893e-e70581f60c7e

	measure 營業額指數 = ```
			
			  VAR base = CALCULATE(
			      SUM('Fact_科學園區營業額'[營業額]),
			      'Dim_Date'[Year] = 2016,
			      ALL('Dim_Date')
			  )
			  RETURN DIVIDE(SUM('Fact_科學園區營業額'[營業額]), base) 
			```
		displayFolder: L3_數位足跡
		lineageTag: 15cf1bd7-3359-4819-ac42-2ad015e54680

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure GDP份額% = ```
			
			  DIVIDE(
			      SUM('Fact_電力密集度年'[GDP合計_連鎖實質_百萬元]),
			      CALCULATE(
			          SUM('Fact_電力密集度年'[GDP合計_連鎖實質_百萬元]),
			          ALL('Fact_電力密集度年'[行業別])
			      )
			  )
			```
		displayFolder: L2_電力效能
		lineageTag: ac9c5438-1644-4f5b-998a-6d4eb32dad02

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 用電份額% = ```
			
			  DIVIDE(
			      SUM('Fact_電力密集度年'[電力消費_千度]),
			      CALCULATE(
			          SUM('Fact_電力密集度年'[電力消費_千度]),
			          ALL('Fact_電力密集度年'[行業別])
			      )
			  )
			```
		displayFolder: L2_電力效能
		lineageTag: 21731372-48bb-4bfe-8140-3f9a5ba8b0b8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 電力密集度_GDP_百萬元 = SUM('Fact_電力密集度年'[GDP合計_連鎖實質_百萬元])
		displayFolder: L2_電力效能
		lineageTag: 0adb6ac5-8416-4034-aa7c-7067f6dd1cd1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 每度電GDP_元 = ```
			
			      -- GDP(百萬元) × 1e6 ÷ 電力消費(千度) × 1e3 = 元/度
			      DIVIDE(
			          SUM('Fact_電力密集度年'[GDP合計_連鎖實質_百萬元]) * 1000,
			          SUM('Fact_電力密集度年'[電力消費_千度])
			      )
			```
		displayFolder: L2_電力效能
		lineageTag: fd1f118b-cefb-4ec0-bce6-1041c237f1c6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure _Proxy_全國年毛發電量 =
			CALCULATE(
			    SUM('Fact_MOEA發電月'[發電量]),
			    'Fact_MOEA發電月'[發電方式] = "總計_毛發電"
			)
		displayFolder: L3_科學園區電源結構
		lineageTag: fa130001-fa13-4001-8013-fa1300000013

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Proxy_燃氣_占比 =
			DIVIDE(
			    CALCULATE(SUM('Fact_MOEA發電月'[發電量]), 'Fact_MOEA發電月'[發電方式] = "燃氣發電"),
			    [_Proxy_全國年毛發電量]
			)
		formatString: 0.00%
		displayFolder: L3_科學園區電源結構
		lineageTag: fa130002-fa13-4002-8013-fa1300000013

	measure Proxy_燃煤_占比 =
			DIVIDE(
			    CALCULATE(SUM('Fact_MOEA發電月'[發電量]), 'Fact_MOEA發電月'[發電方式] = "燃煤發電"),
			    [_Proxy_全國年毛發電量]
			)
		formatString: 0.00%
		displayFolder: L3_科學園區電源結構
		lineageTag: fa130003-fa13-4003-8013-fa1300000013

	measure Proxy_核能_占比 =
			DIVIDE(
			    CALCULATE(SUM('Fact_MOEA發電月'[發電量]), 'Fact_MOEA發電月'[發電方式] = "核能發電"),
			    [_Proxy_全國年毛發電量]
			)
		formatString: 0.00%
		displayFolder: L3_科學園區電源結構
		lineageTag: fa130004-fa13-4004-8013-fa1300000013

	measure Proxy_再生能源_占比 =
			DIVIDE(
			    CALCULATE(SUM('Fact_MOEA發電月'[發電量]), 'Fact_MOEA發電月'[發電方式] = "再生能源合計"),
			    [_Proxy_全國年毛發電量]
			)
		formatString: 0.00%
		displayFolder: L3_科學園區電源結構
		lineageTag: fa130005-fa13-4005-8013-fa1300000013

	measure Proxy_其他_占比 = 1 - [Proxy_燃氣_占比] - [Proxy_燃煤_占比] - [Proxy_核能_占比] - [Proxy_再生能源_占比]
		formatString: 0.00%
		displayFolder: L3_科學園區電源結構
		lineageTag: fa130006-fa13-4006-8013-fa1300000013

	measure 園區_用電量_千度 = SUM('Fact_科學園區用電年'[用電量_千度])
		displayFolder: L3_科學園區電源結構
		lineageTag: fa130007-fa13-4007-8013-fa1300000013

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Proxy_燃氣_估算_千度 = [園區_用電量_千度] * [Proxy_燃氣_占比]
		displayFolder: L3_科學園區電源結構
		lineageTag: fa130008-fa13-4008-8013-fa1300000013

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Proxy_燃煤_估算_千度 = [園區_用電量_千度] * [Proxy_燃煤_占比]
		displayFolder: L3_科學園區電源結構
		lineageTag: fa130009-fa13-4009-8013-fa1300000013

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Proxy_核能_估算_千度 = [園區_用電量_千度] * [Proxy_核能_占比]
		displayFolder: L3_科學園區電源結構
		lineageTag: fa13000a-fa13-400a-8013-fa1300000013

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Proxy_再生能源_估算_千度 = [園區_用電量_千度] * [Proxy_再生能源_占比]
		displayFolder: L3_科學園區電源結構
		lineageTag: fa13000b-fa13-400b-8013-fa1300000013

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Proxy_其他_估算_千度 = [園區_用電量_千度] * [Proxy_其他_占比]
		displayFolder: L3_科學園區電源結構
		lineageTag: fa13000c-fa13-400c-8013-fa1300000013

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 水力發電量 = CALCULATE([發電量_百萬度], 'Fact_MOEA發電月'[發電方式] = "慣常水力發電")
