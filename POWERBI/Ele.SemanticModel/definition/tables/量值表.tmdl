		lineageTag: ffaf8162-81ff-4f2b-9ebe-9afa8b231c2d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 電力密集度_2015指數 =
			VAR base =
			    CALCULATE(
			        [電力密集度_千度per百萬元],
			        FILTER(ALL(Dim_Date), Dim_Date[Year] = 2015)
			    )
			RETURN DIVIDE([電力密集度_千度per百萬元], base) * 100
		formatString: 0.0
		displayFolder: L2_電力效能
		lineageTag: b2010001-b201-4001-8001-b20100000001

