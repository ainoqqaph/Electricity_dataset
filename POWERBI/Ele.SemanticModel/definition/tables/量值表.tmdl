	measure 園區負載率_% =
			-- Average annual load factor across available years
			-- Per year: energy(kWh) / (system peak(kW) x 8760 hrs)
			-- system peak = max of monthly sum of sub-park peaks within that year
			AVERAGEX(
			    INTERSECT(
			        VALUES('Fact_科學園區用電年'[西元年]),
			        VALUES('Fact_科學園區峰值負載'[西元年])
			    ),
			    VAR yr = [西元年]
			    VAR energy_kWh = CALCULATE(
			        SUM('Fact_科學園區用電年'[用電量_千度]),
			        'Fact_科學園區用電年'[西元年] = yr
			    ) * 1000
			    VAR system_peak_kW = CALCULATE(
			        MAXX(
			            SUMMARIZE(
			                'Fact_科學園區峰值負載',
			                'Fact_科學園區峰值負載'[月]
			            ),
			            CALCULATE(SUM('Fact_科學園區峰值負載'[負載_萬KW]))
			        ),
			        'Fact_科學園區峰值負載'[西元年] = yr
			    ) * 10000
			    VAR hours_year = 8760
			    RETURN DIVIDE(energy_kWh, system_peak_kW * hours_year)
			)
		formatString: 0.00%
		displayFolder: KPI量值
		lineageTag: ee1e0000-ee1e-4000-801e-ee1e00000000

	measure 園區營業額_YoY% =
			
			VAR CY = [園區營業額_百萬元]
			VAR PY = CALCULATE([園區營業額_百萬元], SAMEPERIODLASTYEAR(Dim_Date[Date]))
			RETURN DIVIDE(CY - PY, PY)
		formatString: 0.00%
		displayFolder: 時間智慧
		lineageTag: ee1f0000-ee1f-4000-801f-ee1f00000000

	measure 生產指數_YoY% =
			VAR CurrentYear = MAX(Dim_Date[Year])
			VAR CY =
			    CALCULATE(
			        AVERAGE('Fact_製造業生產指數'[生產指數]),
			        FILTER(ALL(Dim_Date), Dim_Date[Year] = CurrentYear)
			    )
			VAR PY =
			    CALCULATE(
			        AVERAGE('Fact_製造業生產指數'[生產指數]),
			        FILTER(ALL(Dim_Date), Dim_Date[Year] = CurrentYear - 1)
			    )
			RETURN DIVIDE(CY - PY, PY)
		formatString: 0.00%
		displayFolder: 時間智慧
		lineageTag: ee200000-ee20-4000-8020-ee2000000000

	measure 備轉容量率_Rolling12M =
			
			AVERAGEX(
			    DATESINPERIOD(Dim_Date[Date], LASTDATE(Dim_Date[Date]), -12, MONTH),
			    [備轉容量率_平均]
			)
