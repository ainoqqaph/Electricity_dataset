	measure 電力產值效率_元per度 =
			-- 營業額欄位實際單位為億元（非百萬元），需乘以 1e8 轉換為元
			VAR rev_nt   = [園區營業額_百萬元] * 1e8
			VAR elec_kwh = [園區高壓用電_億度] * 1e8
			RETURN DIVIDE(rev_nt, elec_kwh)
		displayFolder: L2_電力效能
		lineageTag: ee2e0000-ee2e-4000-802e-ee2e00000000

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 電力密集度_YoY_pct =
			
			VAR CY = [電力密集度_千度per百萬元]
			VAR PY = CALCULATE(
			    [電力密集度_千度per百萬元],
			    FILTER(ALL(Dim_Date), Dim_Date[Year] = SELECTEDVALUE(Dim_Date[Year]) - 1)
			)
			RETURN DIVIDE(CY - PY, PY)
		formatString: 0.00%
		displayFolder: L2_電力效能
		lineageTag: ee2f0000-ee2f-4000-802f-ee2f00000000

	measure 電力密集度_vs2015改善% =
			
			VAR base =
			    CALCULATE(
			        [電力密集度_千度per百萬元],
			        FILTER(ALL(Dim_Date), Dim_Date[Year] = 2015)
			    )
			VAR currentValue = [電力密集度_千度per百萬元]
			RETURN DIVIDE(currentValue - base, base)
		formatString: 0.00%
		displayFolder: L2_電力效能
		lineageTag: ee300000-ee30-4000-8030-ee3000000000

